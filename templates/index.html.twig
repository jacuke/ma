{% extends "base.html.twig" %}

{% block body %}

    <div class="container text-center">
        <div class="row">
            <div class="col">
                <h3>BfArM Electronic Repository</h3>
            </div>
        </div>
        <div class="row">
            {% for key, value in data %}
                <div class="col">
                    <h4>{{ code_title(key) }} Umsteiger</h4>
                    <h6>Original</h6>
                    <a href="/{{ key }}_umsteiger">Link</a><br/><br/>
                    {#<h6>Automatisiert</h6>
                    <a href="/{{ key }}_auto_umsteiger">Link</a><br/><br/>
                    <h6>Kombiniert</h6>
                    <a href="/{{ key }}_combo_umsteiger">Link</a>#}
                </div>
            {% endfor %}
        </div>
        <div class="row">
            {% for key, value in data %}
                <div class="col">
                    <h4>Test</h4>
                    <a href="/{{ key }}_umsteiger_suche">Link</a><br/><br/>
                </div>
            {% endfor %}
        </div>
        <div class="row">
            {% for key, value in data %}
                <div class="col">
                    <h4>{{ code_title(key) }} Codes</h4>
                    <div class="codes-3-col">
                    {% for year in value.years %}
                        <div><a href="/{{ key }}_codes/{{ year }}">{{ year }}</a></div>
                    {% endfor %}
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>

{% endblock %}