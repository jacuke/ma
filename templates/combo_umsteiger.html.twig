{% extends "base.html.twig" %}

{% block title %}Combo-Umsteiger {{ code_title(type) }}{% endblock %}

{% block body %}

    <h4>{{ code_title(type) }} Umsteiger, kombiniert</h4>

    <ul class="nav nav-tabs" id="myTab" role="tablist">
        {% for key, year in data %}
            <li class="nav-item" role="presentation">
                <button class="nav-link {% if not loop.index0 %}active{% endif %}" id="tab-{{ key }}"
                        data-bs-toggle="tab" data-bs-target="#tab-pane-{{ key }}" type="button" role="tab"
                        aria-controls="tab-pane-{{ key }}" aria-selected="true">
                    {{ key }}</button>
            </li>
        {% endfor %}
    </ul>
    <div class="tab-content" id="myTabContent">
        {% for key, year in data %}
            <div class="tab-pane fade {% if not loop.index0 %}show active{% endif %}" id="tab-pane-{{ key }}"
                 role="tabpanel" aria-labelledby="tab-{{ key }}" tabindex="{{ loop.index0 }}">
                <div class="combo-umsteiger">
                    <table class="table table-sm table-striped">
                        <thead>
                        <tr>
                            <th scope="col" class="code">{{ year.prev }}</th>
                            <th scope="col" class="name">Titel</th>
                            <th scope="col" class="split"></th>
                            <th scope="col" class="code">{{ key }}</th>
                            <th scope="col" class="name">Titel</th>
                            <th scope="col" class="split"></th>
                            <th scope="col" class="combo" colspan="3">Automatisiert</th>
                        </tr>
                        </thead>
                        <tbody class="table-group-divider">
                        {% for line in year.codes %}
                            {% set match = 0 %}
                            {% for o,n in year.auto %}
                                {% if o == line.old %}
                                    {% set match = match + 1 %}
                                {% endif %}
                                {% if n == line.new and match > 0%}
                                    {% set match = match * -1 %}
                                {% endif %}
                            {% endfor %}
                            <tr>
                                <td>{{ line.old }}</td>
                                <td>{{ line.old_name }}</td>
                                <td></td>
                                <td>{{ line.new }}</td>
                                <td>{{ line.new_name }}</td>
                                <td></td>
                                {% if match == 0 %}
                                    <td class="code"></td><td class="split"></td><td class="code"></td>
                                {% else %}
                                    <td class="code" {% if match > 0 %}style="color: lightslategray"{% endif %}>
                                        {{ line.old }}
                                    </td>
                                    <td class="split" {% if match > 0 %}style="color: lightslategray"{% endif %}>
                                        →
                                    </td>
                                    <td class="code" {% if match > 0 %}style="color: lightslategray"{% endif %}>
                                        {% if year.auto[line.old] is defined%}
                                            {{ year.auto[line.old] }}
                                        {% endif %}
                                    </td>
                                {% endif %}
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endfor %}
    </div>

{% endblock %}