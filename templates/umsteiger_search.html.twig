{% extends "base.html.twig" %}

{% block title %}Umsteiger Suche/Historie {{ code_title(type) }}{% endblock %}

{% block body %}

    <h4>{{ code_title(type) }} Code-Suche mit Umsteiger-Historie</h4>

    <form method="get">
        <div class="input-group">
            <input name="s" id="codeSearch" type="text" class="form-control" placeholder="Code" aria-label="Code Suche">
            <button type="submit" class="btn btn-primary">Suchen</button>
        </div>
    </form>

    {% if search != '' %}
        <div class="search-results">
        {% if search|length == 1 %}
            Bitte mehr als ein Zeichen eingeben, sonst dauert die Suche viel zu lange.
        {% else %}
            {% if results|length == 0 %}
                Kein Ergebnis für: {{ search }}
            {% elseif results|length == 1 %}
                {{ results[0]|raw }}
            {% else %}
                {% for result in results %}
                    <div class="result-counter">Ergebnis {{ loop.index }} </div>
                    <div>{{ result|raw }}</div>
                    {% if not loop.last %}
                        <div class="separator"></div>
                    {% endif %}
                {% endfor %}
            {% endif %}
        {% endif %}
        </div>
    {% endif %}

    {#
    <table class="table table-sm">
        <thead>
        <tr>
            <th scope="col">Code</th>
            <th scope="col">Titel</th>
        </tr>
        </thead>
        <tbody>
        {% for element in data %}
            <tr>
                <td>{{ element.code }}</td>
                <td>{{ element.name }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>#}

{% endblock %}